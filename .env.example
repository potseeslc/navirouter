PORT=8098
NAVIDROME_URL=http://127.0.0.1:4533
AUDIOMUSE_URL=http://127.0.0.1:8000
# Optional Navidrome SQLite database path. Enables library-scoped AudioMuse candidate filtering.
NAVIDROME_DB_PATH=
# Optional, for local host installs that need to query the DB inside a Docker container.
NAVIDROME_DB_CONTAINER=
NAVIROUTER_DOCKER_CLI=/usr/local/bin/docker
# Optional, if AudioMuse requires bearer auth.
AUDIOMUSE_API_TOKEN=
# Optional, preferred for Docker secrets. Used only when AUDIOMUSE_API_TOKEN is empty.
AUDIOMUSE_API_TOKEN_FILE=
# Comma-separated host:port values allowed as upstream Navidrome targets.
NAVIROUTER_ALLOWED_NAVIDROME_HOSTS=127.0.0.1:4533
# Comma-separated host:port values allowed as upstream AudioMuse targets.
NAVIROUTER_ALLOWED_AUDIOMUSE_HOSTS=127.0.0.1:8000
# Maximum accepted Subsonic form POST body size in bytes.
NAVIROUTER_MAX_BODY_BYTES=1048576
# Navidrome getSong cache for AudioMuse candidate resolution. Set either to 0 to disable.
NAVIROUTER_SONG_CACHE_TTL_SECONDS=300
NAVIROUTER_SONG_CACHE_MAX=5000
# Concurrent Navidrome getSong lookups while resolving AudioMuse candidates.
NAVIROUTER_RESOLVE_CONCURRENCY=8
# Number of recent Subsonic requests exposed in diagnostics.
NAVIROUTER_RECENT_REQUESTS_LIMIT=25
# Optional generic webhook notifications for AudioMuse radio events.
NAVIROUTER_WEBHOOK_URL=
NAVIROUTER_WEBHOOK_EVENTS=radio.generated,radio.playback_confirmed,radio.fallback
NAVIROUTER_WEBHOOK_SECRET=
# Optional, preferred for Docker secrets. Used only when NAVIROUTER_WEBHOOK_SECRET is empty.
NAVIROUTER_WEBHOOK_SECRET_FILE=
NAVIROUTER_WEBHOOK_TIMEOUT_MS=3000
# Maximum pending deliveries; new events are dropped and counted when full.
NAVIROUTER_WEBHOOK_QUEUE_MAX=100
# Maximum Navidrome fallback response inspected before NaviRouter rejects it.
NAVIROUTER_FALLBACK_RESPONSE_MAX_BYTES=1048576
# How long a generated radio remains eligible for playback confirmation.
NAVIROUTER_RADIO_CORRELATION_TTL_SECONDS=21600

# Optional smoke-test settings for `npm run smoke`.
NAVIROUTER_SMOKE_URL=http://127.0.0.1:8098
NAVIROUTER_SMOKE_USERNAME=
NAVIROUTER_SMOKE_PASSWORD=
NAVIROUTER_SMOKE_SEED_ID=
NAVIROUTER_SMOKE_END_ID=
